@model IEnumerable<MiniPlantaJugos.Models.ControlCalidad>

@{
    ViewData["Title"] = "Problemas Graves de Calidad";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Problemas Graves de Calidad</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-shield-plus"></i> Nuevo Control</a>
</div>

<div class="alert alert-danger">
    <i class="bi bi-exclamation-triangle-fill"></i> Esta vista muestra únicamente los controles con resultado <strong>Rechazado</strong>.
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Fecha Control</th>
                        <th>Orden #</th>
                        <th>Producto</th>
                        <th>Observación</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.OrdenProdId</td>
                            <td>@item.ProdRevisada?.Producto?.Nombre</td>
                            <td class="text-danger">@item.Observacion</td>
                            <td>
                                <a asp-controller="Ordenes" asp-action="Details" asp-route-id="@item.OrdenProdId" class="btn btn-sm btn-info text-white" title="Ver Orden">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any()) {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No se encontraron problemas graves.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
