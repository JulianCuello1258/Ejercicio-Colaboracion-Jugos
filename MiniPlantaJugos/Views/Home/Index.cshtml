@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4"><i class="bi bi-speedometer2"></i> Dashboard</h2>

<div class="row g-4">
    <div class="col-md-4 col-lg-3">
        <div class="card text-center p-3">
            <div class="card-body">
                <i class="bi bi-box-seam fs-1 text-success"></i>
                <h5 class="mt-2">Productos Activos</h5>
                <h2 class="fw-bold text-success">@ViewBag.TotalProductos</h2>
                <a asp-controller="Productos" asp-action="Index" class="btn btn-outline-success btn-sm mt-2">Ver todos</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-3">
        <div class="card text-center p-3">
            <div class="card-body">
                <i class="bi bi-gear-fill fs-1 text-primary"></i>
                <h5 class="mt-2">Máquinas</h5>
                <h2 class="fw-bold text-primary">@ViewBag.MaquinasOperativas / @ViewBag.TotalMaquinas</h2>
                <small class="text-muted">Operativas / Total</small><br/>
                <a asp-controller="Maquinas" asp-action="Index" class="btn btn-outline-primary btn-sm mt-2">Ver todas</a>
            </div>
        </div>
    </div>
</div>
