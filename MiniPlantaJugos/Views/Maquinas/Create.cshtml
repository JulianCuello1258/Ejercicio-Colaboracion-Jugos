@model MiniPlantaJugos.Models.Maquina
@using MiniPlantaJugos.Enums
@{
    ViewData["Title"] = "Nueva Máquina";
}

<h2><i class="bi bi-plus-lg"></i> Nueva Máquina</h2>

<div class="card mt-3" style="max-width: 600px;">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej: Envasadora 1" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Sector" class="form-label"></label>
                <input asp-for="Sector" class="form-control" placeholder="Ej: Sector Envasado" />
            </div>
            <div class="mb-3">
                <label asp-for="Precio" class="form-label"></label>
                <input asp-for="Precio" class="form-control" type="number" step="0.01" />
            </div>
            <div class="mb-3">
                <label asp-for="Estado" class="form-label"></label>
                <select asp-for="Estado" asp-items="Html.GetEnumSelectList<EstadoMaquina>()" class="form-select"></select>
            </div>
            <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Guardar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
