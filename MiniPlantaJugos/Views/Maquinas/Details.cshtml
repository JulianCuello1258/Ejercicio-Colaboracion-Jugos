@model MiniPlantaJugos.Models.Maquina
@using MiniPlantaJugos.Enums
@{
    ViewData["Title"] = "Detalle Máquina";
    string badgeClass = Model.Estado == EstadoMaquina.Operativa ? "bg-success" :
                        Model.Estado == EstadoMaquina.Detenida ? "bg-danger" : "bg-warning text-dark";
}

<h2><i class="bi bi-gear-fill"></i> Detalle de Máquina</h2>

<div class="card mt-3" style="max-width: 600px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Id</dt>
            <dd class="col-sm-8">@Model.Id</dd>
            <dt class="col-sm-4">Nombre</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>
            <dt class="col-sm-4">Sector</dt>
            <dd class="col-sm-8">@Model.Sector</dd>
            <dt class="col-sm-4">Precio</dt>
            <dd class="col-sm-8">$@Model.Precio.ToString("N2")</dd>
            <dt class="col-sm-4">Estado</dt>
            <dd class="col-sm-8"><span class="badge @badgeClass">@Model.Estado</span></dd>
        </dl>

    </div>
</div>
<a asp-action="Index" class="btn btn-secondary mt-3"><i class="bi bi-arrow-left"></i> Volver</a>
