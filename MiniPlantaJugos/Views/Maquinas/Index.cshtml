@model IEnumerable<MiniPlantaJugos.Models.Maquina>
@using MiniPlantaJugos.Enums
@{
    ViewData["Title"] = "Máquinas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-gear-fill"></i> Máquinas</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg"></i> Nueva Máquina</a>
</div>

<form method="get" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label">Filtrar por estado:</label>
            <select name="filtroEstado" class="form-select" onchange="this.form.submit()">
                <option value="">-- Todos --</option>
                @foreach (EstadoMaquina e in Enum.GetValues(typeof(EstadoMaquina)))
                {
                    <option value="@e" selected="@(ViewBag.FiltroEstado != null && (EstadoMaquina)ViewBag.FiltroEstado == e)">@e</option>
                }
            </select>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nombre</th>
                    <th>Sector</th>
                    <th>Precio</th>
                    <th>Estado</th>
                    <th>Cambiar Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    string badgeClass = item.Estado == EstadoMaquina.Operativa ? "bg-success" :
                                        item.Estado == EstadoMaquina.Detenida ? "bg-danger" : "bg-warning text-dark";
                    <tr>
                        <td>@item.Id</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id">@item.Nombre</a>
                        </td>
                        <td>@item.Sector</td>
                        <td>$@item.Precio.ToString("N2")</td>
                        <td><span class="badge @badgeClass">@item.Estado</span></td>
                        <td>
                            <form asp-action="CambiarEstado" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <select name="nuevoEstado" class="form-select form-select-sm d-inline-block" style="width:auto;">
                                    @foreach (EstadoMaquina e in Enum.GetValues(typeof(EstadoMaquina)))
                                    {
                                        <option value="@e" selected="@(item.Estado == e)">@e</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-repeat"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
