@model MiniPlantaJugos.Models.OrdenProd

@{
    ViewData["Title"] = "Nueva Orden";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">Crear Orden de Producción</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="ProductoId" class="form-label"></label>
                            <select asp-for="ProductoId" class ="form-select" asp-items="ViewBag.ProductoId">
                                <option value="">Seleccione un producto</option>
                            </select>
                            <span asp-validation-for="ProductoId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MaquinaId" class="form-label"></label>
                            <select asp-for="MaquinaId" class ="form-select" asp-items="ViewBag.MaquinaId">
                                <option value="">Seleccione una máquina</option>
                            </select>
                            <span asp-validation-for="MaquinaId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="CantUnidades" class="form-label"></label>
                            <input asp-for="CantUnidades" class="form-control" type="number" min="1" />
                            <span asp-validation-for="CantUnidades" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Fecha" class="form-label"></label>
                            <input asp-for="Fecha" class="form-control" />
                            <span asp-validation-for="Fecha" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Usuario" class="form-label"></label>
                            <input asp-for="Usuario" class="form-control" placeholder="Quien registra" />
                            <span asp-validation-for="Usuario" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
                        <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Guardar Orden</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
