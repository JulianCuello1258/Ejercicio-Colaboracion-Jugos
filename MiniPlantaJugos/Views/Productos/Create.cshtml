@model MiniPlantaJugos.Models.Producto
@{
    ViewData["Title"] = "Nuevo Producto";
}

<h2><i class="bi bi-plus-lg"></i> Nuevo Producto</h2>

<div class="card mt-3" style="max-width: 600px;">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej: Jugo de Naranja" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TipoEnvase" class="form-label"></label>
                <input asp-for="TipoEnvase" class="form-control" placeholder="Ej: Botella 500ml" />
            </div>
            <div class="mb-3">
                <label asp-for="PrecioEstimado" class="form-label"></label>
                <input asp-for="PrecioEstimado" class="form-control" type="number" step="0.01" />
            </div>
            <div class="mb-3 form-check">
                <input asp-for="Activo" class="form-check-input" />
                <label asp-for="Activo" class="form-check-label"></label>
            </div>
            <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Guardar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
