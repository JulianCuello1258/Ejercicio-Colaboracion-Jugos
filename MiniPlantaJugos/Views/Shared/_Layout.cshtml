<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiniPlanta de Jugos</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background-color: #f8f9fa; }
        .navbar { background: linear-gradient(135deg, #2d6a4f, #40916c) !important; }
        .navbar-brand { font-weight: bold; font-size: 1.3rem; }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08); border-radius: 12px; }
        .btn-success { background-color: #40916c; border-color: #40916c; }
        .btn-success:hover { background-color: #2d6a4f; border-color: #2d6a4f; }
        .table th { background-color: #e9f5ef; }
        .badge-estado { font-size: 0.85rem; }
        footer { background-color: #2d6a4f; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-droplet-fill"></i> MiniPlanta de Jugos
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Productos" asp-action="Index">
                            <i class="bi bi-box-seam"></i> Productos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Maquinas" asp-action="Index">
                            <i class="bi bi-gear-fill"></i> Máquinas
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Ordenes" asp-action="Index">
                            <i class="bi bi-clipboard-check"></i> Órdenes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="ControlCalidad" asp-action="Index">
                            <i class="bi bi-shield-check"></i> Calidad
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Incidentes" asp-action="Index">
                            <i class="bi bi-exclamation-triangle"></i> Incidentes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Usuarios" asp-action="Index">
                            <i class="bi bi-people-fill"></i> Usuarios
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container my-4">
        @RenderBody()
    </div>

    <footer class="text-white text-center py-3 mt-5">
        <small>&copy; 2026 MiniPlanta de Jugos - Ejercicio Colaborativo</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
